{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "KafkaSettings": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "octopus",
    "Topic": "octagon",
    "DlqTopic":  "dead-topic",
    "EnableAutoCommit": false,
    "AutoOffsetReset": "Earliest"
  },
  "KafkaConfig": {
    "ConsumerCount": 1
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "D:\\logs\\poc\\kafka\\consumer\\logs-.log",
          "rollingInterval": "Day",
          "shared": true
        }
      }
    ]
  }
}