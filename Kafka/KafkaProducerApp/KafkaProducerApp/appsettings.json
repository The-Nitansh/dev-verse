{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "KafkaSettings": {
    "BootstrapServers": "localhost:9092",
    "Topic": "octagon",
    "TotalPartitions": 8,
    "Utilities": [
      {
        "Name": "UtilityA",
        "Partitions": [ 0 ]
      }
    ],
    "Utilities_": [
      {
        "Name": "UtilityA",
        "Partitions": [ 0, 1, 4 ]
      },
      {
        "Name": "UtilityB",
        "Partitions": [ 3, 6 ]
      },
      {
        "Name": "UtilityC",
        "Partitions": [ 2, 7 ]
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "D:\\logs\\poc\\kafka\\producer\\logs-.log",
          "rollingInterval": "Day",
          "shared": true
        }
      }
    ]
  }
}